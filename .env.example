# ── Runtime & Shared ──────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
UPLOAD_DIR=./uploads

# ── MongoDB (Shared) ──────────────────────────────────────────────────────────
MONGO_URI=mongodb://root:password@localhost:27017/hls-microservice?authSource=admin
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=password
MONGO_DB=hls-microservice

# ── RabbitMQ (Shared) ─────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=video.transcode

# ── API Gateway (Main Service) ───────────────────────────────────────────────
# PORT defaults to 3000
# SERVICE_NAME defaults to api-gateway
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_BYTES=524288000

# ── Video Processor (Worker) ──────────────────────────────────────────────────
# Worker HTTP health port (PORT defaults to 3001)
# SERVICE_NAME defaults to video-processor
HLS_OUTPUT_DIR=./hls
MAX_CONCURRENT_JOBS=4
# FFMPEG_PATH=  # Uncomment and set if ffmpeg is not in PATH
