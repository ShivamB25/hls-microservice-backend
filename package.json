{
  "name": "hls-microservice-backend",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    ".",
    "video-processing-service",
    "packages/shared"
  ],
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun --minify --sourcemap=linked",
    "dev:worker": "bun run --hot video-processing-service/src/worker.ts",
    "start:worker": "bun run video-processing-service/src/worker.ts",
    "build:worker": "bun build video-processing-service/src/worker.ts --outdir video-processing-service/dist --target bun --minify",
    "build:all": "bun run build && bun run build:worker",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write ."
  },
  "dependencies": {
    "@hls/shared": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.7",
    "mongoose": "^9.3.0",
    "mongoose-paginate-v2": "^1.9.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.19.15",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
